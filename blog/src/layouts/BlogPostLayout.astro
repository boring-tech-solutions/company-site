---
import BlogSeo from '../components/BlogSeo.astro';
import BlogShellLayout from './BlogShellLayout.astro';

interface Props {
  title: string;
  description: string;
  canonicalUrl: string;
  seoTitle: string;
  seoDescription: string;
  datePublished: string;
  dateModified: string;
  author: string;
  tags: string[];
  ogImage?: string;
  category?: string;
}

const {
  title,
  description,
  canonicalUrl,
  seoTitle,
  seoDescription,
  datePublished,
  dateModified,
  author,
  tags,
  ogImage,
  category,
} = Astro.props;

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description: description,
  author: {
    '@type': 'Organization',
    name: author,
  },
  datePublished: datePublished,
  dateModified: dateModified,
  url: canonicalUrl,
  ...(ogImage ? { image: ogImage } : {}),
  ...(category ? { articleSection: category } : {}),
  keywords: tags.join(', '),
  publisher: {
    '@type': 'Organization',
    name: 'Boring Tech Solutions',
    url: 'https://boringtechsolutions.com',
  },
});

const breadcrumbJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://boringtechsolutions.com/' },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: 'https://boringtechsolutions.com/blog/' },
    { '@type': 'ListItem', position: 3, name: title, item: canonicalUrl },
  ],
});
---

<BlogShellLayout>
  <Fragment slot="head">
    <BlogSeo
      title={seoTitle}
      description={seoDescription}
      canonicalUrl={canonicalUrl}
      ogImage={ogImage}
      type="article"
    />
    <script type="application/ld+json" set:text={jsonLd} />
    <script type="application/ld+json" set:text={breadcrumbJsonLd} />
  </Fragment>

  <section class="section-container blog-post-shell">
    <article class="blog-post">
      <nav aria-label="Breadcrumb" class="blog-post__breadcrumb">
        <a href="/blog/">Blog</a>
        <span aria-hidden="true">›</span>
        <span>{title}</span>
      </nav>

      <a href="/blog/" class="blog-post__back-link">← Back to Blog</a>

      <header class="blog-post__header">
        {category && <span class="blog-post__category">{category}</span>}
        <h1>{title}</h1>
        <div class="blog-post__meta">
          <span>By {author}</span>
          <span>Published <time datetime={datePublished}>{datePublished}</time></span>
          {dateModified !== datePublished && (
            <span>Updated <time datetime={dateModified}>{dateModified}</time></span>
          )}
        </div>
        {tags.length > 0 && (
          <div class="blog-post__tags">
            {tags.map((tag) => <span>{tag}</span>)}
          </div>
        )}
      </header>

      <div class="blog-post__content">
        <slot />
      </div>
    </article>
  </section>
</BlogShellLayout>

<style>
  .blog-post-shell {
    padding-block: 3rem 0;
  }

  .blog-post {
    max-width: 48rem;
    margin: 0 auto;
    padding: 2rem;
    border: 1px solid hsl(var(--border));
    border-radius: 1.75rem;
    background:
      linear-gradient(180deg, hsl(var(--card) / 0.88), hsl(var(--surface-dark) / 0.96));
    box-shadow: 0 24px 80px hsl(var(--background) / 0.35);
  }

  .blog-post__breadcrumb {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1rem;
    color: hsl(var(--muted-foreground));
    font-size: 0.9rem;
  }

  .blog-post__breadcrumb a,
  .blog-post__back-link {
    color: hsl(var(--primary));
    text-decoration: none;
  }

  .blog-post__breadcrumb a:hover,
  .blog-post__back-link:hover,
  .blog-post__content a:hover {
    text-decoration: underline;
  }

  .blog-post__back-link {
    display: inline-flex;
    margin-bottom: 1.5rem;
    font-weight: 700;
  }

  .blog-post__header {
    margin-bottom: 2rem;
  }

  .blog-post__category {
    display: inline-flex;
    margin-bottom: 1rem;
    padding: 0.35rem 0.75rem;
    border-radius: 999px;
    background: hsl(var(--primary) / 0.14);
    color: hsl(var(--primary));
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .blog-post h1 {
    margin: 0;
    font-size: clamp(2.2rem, 4vw, 3.5rem);
    line-height: 0.98;
    color: hsl(var(--foreground));
  }

  .blog-post__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1.2rem;
    margin-top: 1rem;
    color: hsl(var(--muted-foreground));
    font-size: 0.95rem;
  }

  .blog-post__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-top: 1rem;
  }

  .blog-post__tags span {
    padding: 0.3rem 0.7rem;
    border-radius: 999px;
    background: hsl(var(--secondary) / 0.8);
    color: hsl(var(--foreground));
    font-size: 0.82rem;
  }

  .blog-post__content {
    font-size: 1.05rem;
    line-height: 1.8;
    color: hsl(var(--foreground));
  }

  .blog-post__content :global(h2) {
    margin: 2.25rem 0 0.85rem;
    font-size: 1.75rem;
    color: hsl(var(--foreground));
  }

  .blog-post__content :global(h3) {
    margin: 1.75rem 0 0.75rem;
    font-size: 1.3rem;
    color: hsl(var(--foreground));
  }

  .blog-post__content :global(p),
  .blog-post__content :global(ul),
  .blog-post__content :global(ol),
  .blog-post__content :global(pre),
  .blog-post__content :global(blockquote) {
    margin: 0 0 1.25rem;
  }

  .blog-post__content :global(ul),
  .blog-post__content :global(ol) {
    padding-left: 1.5rem;
  }

  .blog-post__content :global(li) {
    margin-bottom: 0.5rem;
  }

  .blog-post__content :global(a) {
    color: hsl(var(--primary));
    text-decoration: none;
  }

  .blog-post__content :global(blockquote) {
    padding-left: 1rem;
    border-left: 3px solid hsl(var(--primary) / 0.5);
    color: hsl(var(--muted-foreground));
    font-style: italic;
  }

  .blog-post__content :global(code) {
    padding: 0.15rem 0.35rem;
    border-radius: 0.35rem;
    background: hsl(var(--surface-dark));
    font-size: 0.9em;
    font-family: "SFMono-Regular", Consolas, "Liberation Mono", Menlo, monospace;
  }

  .blog-post__content :global(pre) {
    overflow-x: auto;
    padding: 1rem 1.25rem;
    border-radius: 1rem;
    background: hsl(var(--surface-dark));
    border: 1px solid hsl(var(--border));
  }

  .blog-post__content :global(pre code) {
    padding: 0;
    background: none;
  }

  @media (max-width: 719px) {
    .blog-post-shell {
      padding-top: 2rem;
    }

    .blog-post {
      padding: 1.5rem;
      border-radius: 1.25rem;
    }
  }
</style>
